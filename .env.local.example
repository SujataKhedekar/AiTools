# Optional. The app is "bring your own key": each visitor pastes their own free
# Google Gemini key in the UI (stored in their browser), so you usually need
# NOTHING here.
#
# Set GEMINI_API_KEY only if you want a server-side fallback key for visitors
# who don't enter their own (note: then YOUR key pays for their usage).
# Get a free key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIza...

# Optional: change the model or switch providers entirely (OpenAI-compatible).
# AI_MODEL=gemini-2.0-flash
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#
# Example — switch to Groq (also free) without code changes:
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile
