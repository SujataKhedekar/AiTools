# Optional. The app is "bring your own key": each visitor pastes their own free
# Groq key in the UI (stored in their browser), so you usually need NOTHING here.
#
# Set GROQ_API_KEY only if you want a server-side fallback key for visitors who
# don't enter their own (note: then YOUR key pays for their usage).
# Get a free key at https://console.groq.com/keys
# GROQ_API_KEY=gsk_...

# Optional: change the model or switch providers (OpenAI-compatible).
# AI_MODEL=llama-3.3-70b-versatile
# AI_BASE_URL=https://api.groq.com/openai/v1
#
# Example — switch to Google Gemini instead (free, but unreliable from cloud hosts):
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# AI_MODEL=gemini-2.0-flash
