# Copy this file to .env.local and fill in your key.
# Get a key at https://platform.claude.com

ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (defaults to claude-opus-4-8).
# For high-volume / lower-cost use, try claude-sonnet-4-6 or claude-haiku-4-5.
# ANTHROPIC_MODEL=claude-opus-4-8
